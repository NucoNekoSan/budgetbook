SECRET_KEY=change-me-to-a-random-string
DEBUG=False
# スマホや他端末からアクセスする場合は PC の LAN IP を追加してください
# 例: ALLOWED_HOSTS=127.0.0.1,localhost,192.168.1.10
ALLOWED_HOSTS=127.0.0.1,localhost

# --- 公開モード（HTTPS 環境向け） ---
# ENABLE_HTTPS=1 にすると secure cookie / HSTS / SSL リダイレクトが有効になります
# LAN 内 HTTP 運用ではコメントアウトのままにしてください
# ENABLE_HTTPS=1
# SECURE_HSTS_SECONDS=31536000
# HSTS preload は安定運用を確認してから有効化してください
# ENABLE_HSTS_PRELOAD=1
# CSRF_TRUSTED_ORIGINS=https://example.com

# --- 管理画面 URL ---
# デフォルトは admin/ です。公開時は推測されにくいパスに変更してください
# ADMIN_URL_PATH=my-secret-admin/

# --- セッション ---
# セッション有効期間（秒）。デフォルト 86400（24 時間）
# SESSION_COOKIE_AGE=86400

# --- ログイン試行回数制限 (django-axes) ---
# AXES_FAILURE_LIMIT=5
# AXES_COOLOFF_TIME=0.5